<configuration scan="true" scanPeriod="20 seconds">
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/src/repos/reneekbartlett/portfolio/parent/logs/verisimilar-core-test.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
            <fileNamePattern>/src/repos/reneekbartlett/portfolio/parent/logs/verisimilar-core-test.%i.log.gz</fileNamePattern>
            <minIndex>1</minIndex>
            <maxIndex>5</maxIndex>
        </rollingPolicy>
        <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
            <maxFileSize>100MB</maxFileSize>
        </triggeringPolicy>
        <encoder>
            <pattern>%X{file_id} %d [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <springProfile name="dev">
        <include resource="org/springframework/boot/logging/logback/base.xml" />
    </springProfile>
    <springProfile name="default">
        <appender name="jsonConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
        </appender>
        <root level="DEBUG">
            <appender-ref ref="jsonConsoleAppender" />
        </root>
    </springProfile>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <appender name="STDOUT_DATA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>
    <logger name="com.reneekbartlett.verisimilar.core.util.PersonGeneratorTests" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT_DATA" />
    </logger>
    <logger name="com.reneekbartlett.verisimilar.core.util.PostalAddressGeneratorTests" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT_DATA" />
    </logger>
    <root level="INFO">
        <appender-ref ref="STDOUT_DATA" />
        <appender-ref ref="ROLLING_FILE" />
    </root>
</configuration>
